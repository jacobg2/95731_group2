# Copy this file to .env and fill in the secrets. .env is gitignored.

# --- Django ---
# Generate a real key for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-only-key-do-not-use-in-production
DEBUG=True
# Comma-separated. Add your EC2 public DNS/IP here when deploying.
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated full origins (scheme included), e.g. https://ec2-x-x-x-x.compute-1.amazonaws.com
CSRF_TRUSTED_ORIGINS=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Printed by `python manage.py upload_reference` after the first upload.
OPENAI_VECTOR_STORE_ID=
